# Event-Driven Order Processing System
# Environment Configuration Example

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MySQL Configuration
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=orderuser
MYSQL_PASSWORD=orderpass123
MYSQL_DATABASE=orderdb

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Debug and Logging
DEBUG=False
LOG_LEVEL=INFO

# API Configuration (Order Service)
API_PORT=8000

# ============================================
# KAFKA CONFIGURATION
# ============================================

# Kafka Bootstrap Servers
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Kafka Topics
ORDER_TOPIC=order-events
INVENTORY_UPDATE_TOPIC=inventory-events
FAILED_ORDERS_TOPIC=failed-orders
NOTIFICATION_TOPIC=notification-events
DLQ_TOPIC=dlq-events

# Consumer Groups
INVENTORY_CONSUMER_GROUP=inventory-service
NOTIFICATION_CONSUMER_GROUP=notification-service

# Kafka Consumer Settings
KAFKA_SESSION_TIMEOUT=30000
KAFKA_MAX_POLL_RECORDS=10
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10

# ============================================
# OUTBOX CONFIGURATION (Order Service)
# ============================================

# Transactional Outbox Pattern Settings
OUTBOX_POLL_INTERVAL=5
OUTBOX_BATCH_SIZE=100

# ============================================
# RETRY AND ERROR HANDLING
# ============================================

# Retry Configuration
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2.0

# ============================================
# NOTES
# ============================================

# 1. DB_USER and DB_PASSWORD should match MYSQL_USER and MYSQL_PASSWORD
# 2. All services connect to the same MySQL database (orderdb)
# 3. Kafka topics will be auto-created if KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
# 4. Adjust LOG_LEVEL to DEBUG for more detailed logging
# 5. For production, use strong passwords and secure configurations
